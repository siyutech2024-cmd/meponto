# MePonto / PontoSys environment template
# Copy to .env.local for local development. Never commit real secrets.

# App
NEXT_PUBLIC_APP_NAME="MePonto PontoSys"
NEXT_PUBLIC_APP_ENV="development"
AUTH_SESSION_SECRET=""

# Supabase public client
NEXT_PUBLIC_SUPABASE_URL=""
NEXT_PUBLIC_SUPABASE_ANON_KEY=""

# Supabase server-side access
SUPABASE_SERVICE_ROLE_KEY=""

# Database persistence: when "true", every in-memory collection is mirrored to
# the Supabase app_state_records table and restored on server start.
USE_SUPABASE="true"

# Supabase Postgres connection strings
# Use pooled DATABASE_URL for app runtime and DIRECT_URL for migrations/admin jobs.
DATABASE_URL=""
DIRECT_URL=""

# Optional future services
REDIS_URL=""
SENTRY_DSN=""

# Immutable business constants
POINTS_PER_BRL="10"
QR_CODE_TTL_SECONDS="60"
QR_MAX_DISTANCE_METERS="50"
