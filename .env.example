# Supabase project API settings. Use the values from Project Settings > API.
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Server-only Supabase access. Never expose this value with NEXT_PUBLIC_.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Direct Postgres connection used by migrations and future server adapters.
DATABASE_URL=postgresql://postgres.your-project-ref:your-password@aws-0-region.pooler.supabase.com:6543/postgres

# Optional integration providers exposed by GET /api/integrations.
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_VERIFY_TOKEN=
MAPS_API_KEY=
OBJECT_STORAGE_BUCKET=
OBJECT_STORAGE_REGION=
OBJECT_STORAGE_ACCESS_KEY_ID=
OBJECT_STORAGE_SECRET_ACCESS_KEY=
PIX_PAYOUT_API_KEY=
PIX_PAYOUT_ACCOUNT_ID=
PIX_PAYOUT_WEBHOOK_SECRET=
SMS_PROVIDER_API_KEY=
SMS_FROM_NUMBER=
EMAIL_PROVIDER_API_KEY=
EMAIL_FROM_ADDRESS=
